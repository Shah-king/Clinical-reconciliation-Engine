# ============================================================
# Clinical Reconciliation Engine — Frontend Environment
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ⚠️  SECURITY NOTE — VITE_API_KEY is baked into the browser bundle at
# build time and is visible to anyone who loads the app.
#
# Acceptable for: internal tools, development, behind a VPN/auth wall.
# NOT acceptable for: public-facing deployments.
#
# For production, proxy API calls through your own backend-for-frontend
# (BFF) that holds the real API key server-side, and authenticate users
# with a session cookie or short-lived token instead.
# ============================================================

# Must match the API_KEY value in the backend .env
VITE_API_KEY=CHANGE_ME_must_match_backend_API_KEY

# Backend base URL — the Vite dev proxy rewrites /api → backend automatically
# Change to your deployed backend URL for production builds
VITE_API_BASE_URL=/api
