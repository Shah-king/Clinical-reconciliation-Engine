# ============================================================
# Clinical Reconciliation Engine — Backend Environment
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ----------------------------------------------------------
# REQUIRED — change both before any deployment
# ----------------------------------------------------------

# Your own API key — sent by callers in the x-api-key header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=CHANGE_ME_use_secrets.token_hex_32

# Google Gemini API key — FREE at https://aistudio.google.com/apikey
# Free tier: gemini-1.5-flash — 15 requests/min, 1 500 requests/day
# Leave blank to run without LLM (deterministic scoring still works).
GEMINI_API_KEY=

# ----------------------------------------------------------
# Gemini tuning (optional — defaults shown)
# ----------------------------------------------------------
GEMINI_MODEL=gemini-1.5-flash-8b
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_DELAY=1.0

# ----------------------------------------------------------
# Server behaviour (optional — defaults shown)
# ----------------------------------------------------------

# Set to true only in local development — disables /docs and /redoc in production
DEBUG=false

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ----------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# In production replace with your actual frontend URL(s)
# ----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------
# Rate limiting (requests per minute per API key)
# ----------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ----------------------------------------------------------
# Cache TTL in seconds (default: 24 hours)
# ----------------------------------------------------------
CACHE_TTL_SECONDS=86400
